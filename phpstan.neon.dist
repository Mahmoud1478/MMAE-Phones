includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: max

    paths:
        - src

    excludePaths:
        - src/tests

    # CountryDetector::detect() is the hot path. It deliberately trusts the shape
    # of the baked `config/phone-lookup.php` index and drops per-call type guards
    # (is_array/is_int/is_string), which measured ~10-15% of its cost. The lookup
    # trie is a recursive, heterogeneous structure PHPStan cannot express as a
    # static shape, so the `mixed`-access errors from that ONE method are ignored
    # below. Each is pinned by identifier + exact count and scoped to the file, so
    # any new or unrelated error of the same kind (e.g. in the cold compile/build
    # methods) raises the count and still fails analysis. A malformed lookup is a
    # regenerate-it-yourself contract (`php artisan phones:build-lookup`).
    ignoreErrors:
        -
            identifier: offsetAccess.nonOffsetAccessible
            path: src/CountryDetector.php
            count: 4
        -
            identifier: foreach.nonIterable
            path: src/CountryDetector.php
            count: 4
        -
            identifier: offsetAccess.nonArray
            path: src/CountryDetector.php
            count: 3
        -
            identifier: argument.type
            path: src/CountryDetector.php
            count: 2
        -
            identifier: offsetAccess.invalidOffset
            path: src/CountryDetector.php
            count: 2
        -
            identifier: return.type
            path: src/CountryDetector.php
            count: 3
