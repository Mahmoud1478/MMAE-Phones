{
    "name": "mmae/phones",
    "description": "Validate and normalize phone numbers for 209 countries, with drop-in Laravel validation rules (exists/unique, translations, nullable).",
    "version": "2.0.0",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "MMAE\\Phones\\": "src/",
            "MMAE\\Phones\\Tests\\": "src/tests"
        }
    },
    "authors": [
        {
            "name": "mahmoud mostafa",
            "email": "mah.mostafa18@gmail.com",
            "homepage": "https://mahmoud-mostafa.com",
            "role": "Senior Full-Stack Developer"
        }
    ],
    "minimum-stability": "dev",
    "require-dev": {
        "livewire/livewire": "^4.0",
        "orchestra/testbench": "^11.0",
        "laravel/pint": "^1.18",
        "pestphp/pest": "^4.0",
        "phpunit/phpunit": "^12.5.22",
        "phpstan/phpstan": "^2.1",
        "larastan/larastan": "^3.1",
        "rector/rector": "^2.5",
        "driftingly/rector-laravel": "^2.5"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MMAE\\Phones\\MMAEPhonesServiceProvider"
            ]
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build-lookup": "@php vendor/bin/testbench phones:build-lookup --path=config/phone-lookup.php --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "analyse": [
            "@php vendor/bin/phpstan analyse"
        ],
        "format": [
            "@php vendor/bin/pint --parallel"
        ],
        "refactor": [
            "@php vendor/bin/rector process"
        ],
        "test": [
            "@php -d error_reporting=24575 vendor/bin/pest --test-directory=src/tests --parallel"
        ],
        "lint": [
            "@php vendor/bin/pint --ansi",
            "@php vendor/bin/phpstan analyse --verbose --ansi"
        ]
    }
}